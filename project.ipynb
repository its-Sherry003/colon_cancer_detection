   "source": [
    "# Check for unreadable/corrupted images\n",
    "broken = []  # collect paths that fail to open\n",
    "\n",
    "for path in eda_df['filepath']:\n",
    "    try:\n",
    "        Image.open(path)  # attempt to open\n",
    "    except:\n",
