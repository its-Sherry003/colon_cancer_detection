   "source": [
    "# Define base dataset folder and split-specific paths\n",
    "dataset_path = \"dataset\"  # root folder holding train/val/test\n",
    "\n",
    "train_path = os.path.join(dataset_path, \"train\")  # training images\n",
    "val_path = os.path.join(dataset_path, \"val\")  # validation images\n",
    "test_path = os.path.join(dataset_path, \"test\")  # test images"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "578810c3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Inspect available class folders under the training split\n",
    "classes = os.listdir(train_path)  # list class folder names inside train\n",
    "print(\"Classes:\", classes)  # show class labels detected"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b59ca67e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Helper to count images per class inside a split folder\n",
    "def count_images(folder):\n",
    "    counts = {}  # accumulator for {class: count}\n",
    "    for cls in os.listdir(folder):  # iterate class folders\n",
    "        cls_path = os.path.join(folder, cls)  # full path to class dir\n",
    "        counts[cls] = len(os.listdir(cls_path))  # number of files in class dir\n",
    "    return counts\n",
    "\n",
    "# Tally image counts across splits to check balance\n",
    "train_counts = count_images(train_path)\n",
    "val_counts = count_images(val_path)\n",
    "test_counts = count_images(test_path)\n",
    "\n",
    "print(\"Train:\", train_counts)\n",
    "print(\"Validation:\", val_counts)\n",
    "print(\"Test:\", test_counts)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "67ea7db8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize class distribution in the training split\n",
    "plt.figure(figsize=(8,5))  # set canvas size\n",
    "sns.barplot(x=list(train_counts.keys()), y=list(train_counts.values()))  # bars for each class count\n",
    "plt.title(\"Training Data Distribution\")  # chart title\n",
    "plt.xlabel(\"Class\")\n",
    "plt.ylabel(\"Number of Images\")\n",
    "plt.xticks(rotation=30)  # tilt labels for readability\n",
    "plt.show()"
   ]
